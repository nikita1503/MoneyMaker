# Required
CRUSTDATA_API_KEY=your_crustdata_token_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional — set to "true" to use Crustdata's v2 /company/search endpoint
# (requires a separate credit tier). When false/unset, the v1 endpoint is used.
CRUSTDATA_USE_V2=

# Optional — SMTP for /send. If unset, emails are written to data/sent/*.eml for manual dispatch.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Your Name <you@example.com>"

# Dev mode — if set, every outbound email is redirected to this address
# (real recipient is stamped into the subject + body). Leave blank in prod.
DEV_MODE_EMAIL=

# Payment line shown in outreach emails
PAYMENT_DETAILS="Paypal: you@example.com  |  Stripe: https://buy.stripe.com/xxx"
